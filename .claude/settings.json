{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
  
    "model": "claude-sonnet-4-6",
    "language": "english",
    "outputStyle": "Explanatory",
    "effortLevel": "medium",
    "alwaysThinkingEnabled": false,
    "autoUpdatesChannel": "stable",
  
    "permissions": {
      "defaultMode": "bypassPermissions",
      "allow": [
        "Agent",
        "Bash",
        "Edit",
        "Glob",
        "Grep",
        "KillShell",
        "LSP",
        "NotebookEdit",
        "Read",
        "Skill",
        "TaskCreate",
        "TaskGet",
        "TaskList",
        "TaskOutput",
        "TaskStop",
        "TaskUpdate",
        "TodoWrite",
        "ToolSearch",
        "WebFetch",
        "WebSearch",
        "Write"
      ],
      "ask": [],
      "deny": [],
      "additionalDirectories": [],
      "skipDangerousModePermissionPrompt": true
    },
  
    "sandbox": {
      "enabled": false,
      "failIfUnavailable": false,
      "autoAllowBashIfSandboxed": true,
      "excludedCommands": [
        "docker *",
        "colima *"
      ],
      "filesystem": {
        "allowWrite": ["/tmp", "./dist", "./.next"],
        "denyWrite": ["/etc", "/usr/local/bin"],
        "denyRead": ["~/.aws/credentials", "~/.ssh/id_rsa"],
        "allowRead": ["."]
      },
      "network": {
        "allowedDomains": [
          "github.com",
          "*.npmjs.org",
          "api.anthropic.com"
        ],
        "allowUnixSockets": ["/var/run/docker.sock"],
        "allowLocalBinding": true,
        "allowAllUnixSockets": false
      }
    },
  
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Bash(git commit *)",
          "hooks": [
            {
              "type": "command",
              "command": "pnpm lint-fix && pnpm typecheck"
            }
          ]
        }
      ],
      "PostToolUse": [
      ],
      "Stop": [
        {
          "matcher": "*",
          "hooks": [
            {
              "type": "command",
              "command": "echo 'Claude done'"
            }
          ]
        }
      ]
    },
  
    "disableAllHooks": false,
    "allowedHttpHookUrls": [],
    "httpHookAllowedEnvVars": [],
  
    "worktree": {
      "symlinkDirectories": [
        "node_modules",
        ".cache"
      ],
      "sparsePaths": []
    },
  
    "plansDirectory": "./plans",
    "includeGitInstructions": true,
    "respectGitignore": true,
    "claudeMdExcludes": [],
  
    "env": {
      "NODE_ENV": "development",
      "CLAUDE_CODE_ENABLE_TASKS": "false",
      "CLAUDE_CODE_DEBUG_LOG_LEVEL": "verbose",
      "CLAUDE_CODE_DEBUG_LOGS_DIR": "./agents/agent.logs/claude-debug.log"
    },
  
    "prefersReducedMotion": false,
    "spinnerTipsEnabled": true,
    "showClearContextOnPlanAccept": true,
    "showThinkingSummaries": false,
    "feedbackSurveyRate": 0,
    "cleanupPeriodDays": 30,
  
    "attribution": {
      "commit": "🤖 Generated with Claude Code\n\nCo-Authored-By: Claude <[email protected]>",
      "pr": ""
    },
  
    "availableModels": [
      "best",
      "sonnet",
      "opus",
      "haiku",
      "sonnet[1m]",
      "opus[1m]",
      "opusplan"
    ]
  }