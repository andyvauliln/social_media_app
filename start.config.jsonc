{
  "services": [
    {
      "name": "cron-supervisor",
      "description": "Scheduled GitHub Actions and periodic tasks",
      "type": "app",
      "developmentEnabled": true,
      "productionEnabled": true,
      "serviceManaged": true, // managed by launchd (macOS) / systemd (Linux) — not started by rstart.sh
      "envFiles": [],
      "path": "apps/cron-supervisor",
      "init": "bun install",
      "start": "bun index.mjs"
    },
    {
      "name": "open-screen",
      "description": "OpenScreen content factory UI",
      "type": "github-project",
      "developmentEnabled": false,
      "productionEnabled": false,
      "envFiles": [],
      "path": "github-projects/content-factory/openscreen/repo",
      "init": "bash ../openscreen.init.sh",
      "start": "bash ../openscreen.start.sh"
    },
    {
      "name": "main",
      "description": "Content generation and publishing agent",
      "type": "agent",
      "developmentEnabled": false,
      "productionEnabled": true,
      "envFiles": [],
      "path": ".",
      "init": "bun install",
      "start": "bash ./ragent.sh --telegram"
    },
    {
      "name": "manager",
      "description": "Content generation and publishing agent",
      "type": "agent",
      "developmentEnabled": false,
      "productionEnabled": false,
      "envFiles": [],
      "path": "agents/agent.manager",
      "init": "bun install",
      "start": "bash ./ragent.manager.sh"
    },
    {
      "name": "dante",
      "description": "Content generation and publishing agent",
      "type": "agent",
      "developmentEnabled": false,
      "productionEnabled": true,
      "envFiles": [],
      "path": "agents/agent.dante",
      "init": "bun install",
      "start": "bash ./ragent.dante.sh --telegram"
    },
    {
      "name": "brightbean-studio",
      "description": "Self-hosted social media management platform — schedule, publish, and monitor content across 10+ social networks",
      "type": "github-project",
      "developmentEnabled": false,
      "productionEnabled": false,
      "port": 8000,
      "envFiles": ["envs/gp.brightbean-studio.symlink.env"],
      "path": "github-projects/content-factory/brightbean-studio/repo",
      "init": "bash ../brightbean-studio.init.sh",
      "start": "bash ../brightbean-studio.start.sh"
      // requires .env file — copy from .env.example and fill SECRET_KEY, ENCRYPTION_KEY_SALT, DATABASE_URL
      // for production: use docker compose up -d --build with docker-compose.prod.yml
    },
    {
      "name": "postiz-app",
      "description": "Open-source AI social media scheduling suite with NextJS frontend, NestJS backend, and orchestration workers",
      "type": "github-project",
      "developmentEnabled": false,
      "productionEnabled": false,
      "port": 4200,
      "envFiles": ["envs/gp.postiz-app.symlink.env"],
      "path": "github-projects/content-factory/postiz-app/repo",
      "init": "bash ../postiz-app.init.sh",
      "start": "bash ../postiz-app.start.sh"
      // frontend is typically available on 4200, backend on 3000 (from .env.example)
      // requires PostgreSQL + Redis and a configured .env file
      // alternative local stack: docker compose -f docker-compose.dev.yaml up -d
    },
    {
      "name": "BMAD-METHOD",
      "description": "Agile AI-driven development framework — installs 12+ expert agent personas and 34+ workflows into any project's .claude/ folder",
      "type": "github-project",
      "developmentEnabled": false,
      "productionEnabled": false,
      "envFiles": [],
      "path": "github-projects/coding-terminals/BMAD-METHOD/repo",
      "init": "bash ../BMAD-METHOD.init.sh",
      "start": "bash ../BMAD-METHOD.start.sh"
      // not a running service — invoke manually to install agents/workflows into a target project
      // non-interactive: node tools/installer/bmad-cli.js install --directory /path --modules bmm --tools claude-code --yes
    },
    {
      "name": "claude-code",
      "description": "Research copy of Claude Code source tree",
      "type": "github-project",
      "developmentEnabled": false,
      "productionEnabled": false,
      "envFiles": ["envs/gp.claude-code.symlink.env"],
      "path": "github-projects/coding-terminals/claude-code/repo",
      "init": "bash ../claude-code.init.sh",
      "start": "bash ../claude-code.start.sh"
    },
    {
      "name": "everything-claude-code",
      "description": "Toolkit collection of Claude Code agents, hooks, and workflows",
      "type": "github-project",
      "developmentEnabled": false,
      "productionEnabled": false,
      "envFiles": ["envs/gp.everything-claude-code.symlink.env"],
      "path": "github-projects/coding-terminals/everything-claude-code/repo",
      "init": "bash ../everything-claude-code.init.sh",
      "start": "bash ../everything-claude-code.start.sh"
    },
    {
      "name": "hermes-agent",
      "description": "Self-improving AI agent runtime",
      "type": "github-project",
      "developmentEnabled": false,
      "productionEnabled": false,
      "envFiles": ["envs/gp.hermes-agent.symlink.env"],
      "path": "github-projects/coding-terminals/hermes-agent/repo",
      "init": "bash ../hermes-agent.init.sh",
      "start": "bash ../hermes-agent.start.sh"
    },
    {
      "name": "pi-mono",
      "description": "Monorepo with coding-agent CLI and supporting packages",
      "type": "github-project",
      "developmentEnabled": false,
      "productionEnabled": false,
      "envFiles": [],
      "path": "github-projects/coding-terminals/pi-mono/repo",
      "init": "bash ../pi-mono.init.sh",
      "start": "bash ../pi-mono.start.sh"
    },
    {
      "name": "claude-code-output-styles",
      "description": "Collection of output style prompts for Claude Code",
      "type": "github-project",
      "developmentEnabled": false,
      "productionEnabled": false,
      "envFiles": [],
      "path": "github-projects/content-factory/claude-code-output-styles/repo",
      "init": "bash ../claude-code-output-styles.init.sh",
      "start": "bash ../claude-code-output-styles.start.sh"
    },
    {
      "name": "OpenMontage",
      "description": "Agentic open-source video production system",
      "type": "github-project",
      "developmentEnabled": false,
      "productionEnabled": false,
      "envFiles": ["envs/gp.OpenMontage.symlink.env"],
      "path": "github-projects/content-factory/OpenMontage/repo",
      "init": "bash ../OpenMontage.init.sh",
      "start": "bash ../OpenMontage.start.sh"
      // requires Python 3.10+, Node.js 18+, and FFmpeg on host
    }
  ]
}
