{
  "services": [
    {
      "name": "cron-supervisor",
      "description": "Scheduled GitHub Actions and periodic tasks",
      "type": "app",
      "enabled": true,
      "path": "apps/cron-supervisor",
      "init": "bun install",
      "start": "bun run start"
    },
    {
      "name": "telegram-bot",
      "description": "Telegram bot for notifications and commands",
      "type": "app",
      "enabled": false,
      "path": "apps/telegram-bot",
      "init": "pip install -r requirements.txt",
      "start": "python3 main.py"
    },
    {
      "name": "open-screen",
      "description": "OpenScreen content factory UI",
      "type": "github-project",
      "enabled": false,
      "path": "github-projects/content-factory/openscreen",
      "init": "bun install",
      "start": "bun run dev"
    },
    {
      "name": "content-factory",
      "description": "Content generation and publishing agent",
      "type": "agent",
      "enabled": true,
      "path": "agents/agent.content-factory",
      "init": "bun install"
      // agents are never auto-started -- run independently from their folder, "enabled": true, means it need to be installed
    },
    {
      "name": "brightbean-studio",
      "description": "Self-hosted social media management platform — schedule, publish, and monitor content across 10+ social networks",
      "type": "github-project",
      "enabled": false,
      "path": "github-projects/content-factory/brightbean-studio",
      "init": "python3.12 -m pip install -r requirements.txt && python3.12 manage.py migrate",
      "start": "python3.12 manage.py runserver"
      // requires .env file — copy from .env.example and fill SECRET_KEY, ENCRYPTION_KEY_SALT, DATABASE_URL
      // for production: use docker compose up -d --build with docker-compose.prod.yml
    },
    {
      "name": "BMAD-METHOD",
      "description": "Agile AI-driven development framework — installs 12+ expert agent personas and 34+ workflows into any project's .claude/ folder",
      "type": "github-project",
      "enabled": true,
      "path": "github-projects/coding-terminals/BMAD-METHOD",
      "init": "npm install --no-workspaces",
      "start": "node tools/installer/bmad-cli.js install"
      // not a running service — invoke manually to install agents/workflows into a target project
      // non-interactive: node tools/installer/bmad-cli.js install --directory /path --modules bmm --tools claude-code --yes
    }
  ]
}
