// =============================================================================
// Claude Code — CLI Reference  (claude --help expanded)
// =============================================================================
//
// Binary: claude
// Entry:  src/entrypoints/cli.tsx
//
// General form:
//   claude [global-flags] [prompt]
//   claude [subcommand] [subcommand-flags] [args]
//
// Notation:
//   <arg>       Required argument
//   [arg]       Optional argument
//   a|b|c       Enumerated choices
//   ...         Repeatable (pass flag multiple times or space-separated)
//   *hidden*    Not shown in --help but functional
//   *feature*   Only active when the matching build feature flag is enabled
//
// =============================================================================

{

  // ---------------------------------------------------------------------------
  // VERSION / BASIC INFO
  // ---------------------------------------------------------------------------

  "version": {
    "flags": ["-v", "--version", "-V"],
    "description": "Print the installed Claude Code version and exit immediately (no other modules loaded).",
    "example": "claude --version"
  },

  "help": {
    "flags": ["-h", "--help"],
    "description": "Print usage summary and all visible flags.",
    "example": "claude --help"
  },

  // ---------------------------------------------------------------------------
  // POSITIONAL
  // ---------------------------------------------------------------------------

  "prompt": {
    "type": "string (positional)",
    "description": "Optional prompt passed directly to Claude. When provided, Claude starts processing immediately. When omitted, Claude opens the interactive REPL.",
    "examples": [
      "claude \"explain this codebase\"",
      "claude \"fix the failing tests\"",
      "echo 'what is 2+2' | claude -p"
    ]
  },

  // ---------------------------------------------------------------------------
  // CORE FLAGS
  // ---------------------------------------------------------------------------

  "core": {

    // ── -p / --print ─────────────────────────────────────────────────────────
    "--print": {
      "flags": ["-p", "--print"],
      "type": "boolean",
      "default": false,
      "description": "Non-interactive mode. Print Claude's response to stdout and exit. Required for piping output to other commands.",
      "examples": [
        "claude -p \"summarise README.md\"",
        "claude --print \"what does this file do?\" < src/main.ts",
        "echo 'explain errors' | claude -p --output-format json"
      ]
    },

    // ── --output-format ───────────────────────────────────────────────────────
    "--output-format": {
      "flags": ["--output-format <format>"],
      "type": "enum",
      "values": ["text", "json", "stream-json"],
      "default": "text",
      "requires": "--print",
      "description": "Controls how Claude's response is serialized to stdout.\n  text        — plain text (default)\n  json        — single JSON object after full completion\n  stream-json — newline-delimited JSON events as they arrive",
      "examples": [
        "claude -p \"list files\" --output-format json",
        "claude -p \"build the app\" --output-format stream-json",
        "claude -p \"explain\" --output-format stream-json | jq '.content'"
      ]
    },

    // ── --input-format ────────────────────────────────────────────────────────
    "--input-format": {
      "flags": ["--input-format <format>"],
      "type": "enum",
      "values": ["text", "stream-json"],
      "requires": "--print",
      "description": "Format of stdin input when piping into Claude.\n  text        — plain text (default)\n  stream-json — newline-delimited JSON events (for SDK chaining)",
      "example": "cat messages.jsonl | claude -p --input-format stream-json --output-format stream-json"
    },

    // ── --json-schema ─────────────────────────────────────────────────────────
    "--json-schema": {
      "flags": ["--json-schema <schema>"],
      "type": "string (JSON)",
      "description": "JSON Schema string that constrains the output format. Forces Claude to return structured data matching the schema.",
      "example": "claude -p \"extract name and email\" --json-schema '{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"email\":{\"type\":\"string\"}}}'"
    },

    // ── --include-partial-messages ────────────────────────────────────────────
    "--include-partial-messages": {
      "flags": ["--include-partial-messages"],
      "type": "boolean",
      "default": false,
      "requires": "--print",
      "description": "Emit partial assistant message chunks as they stream in (only meaningful with stream-json output).",
      "example": "claude -p \"write a story\" --output-format stream-json --include-partial-messages"
    },

    // ── --include-hook-events ─────────────────────────────────────────────────
    "--include-hook-events": {
      "flags": ["--include-hook-events"],
      "type": "boolean",
      "default": false,
      "requires": "--output-format stream-json",
      "description": "Include hook lifecycle events (PreToolUse, PostToolUse, etc.) in the stream-json output.",
      "example": "claude -p \"run tests\" --output-format stream-json --include-hook-events"
    }

  },

  // ---------------------------------------------------------------------------
  // SESSION / CONVERSATION
  // ---------------------------------------------------------------------------

  "session": {

    // ── -c / --continue ───────────────────────────────────────────────────────
    "--continue": {
      "flags": ["-c", "--continue"],
      "type": "boolean",
      "default": false,
      "description": "Resume the most recent conversation in the current working directory.",
      "examples": [
        "claude -c",
        "claude -c \"now add tests for that\"",
        "claude --continue -p \"what did we just do?\""
      ]
    },

    // ── -r / --resume ─────────────────────────────────────────────────────────
    "--resume": {
      "flags": ["-r [value]", "--resume [value]"],
      "type": "string | boolean",
      "default": false,
      "description": "Resume a specific conversation by session ID, or open the interactive session picker when no value is given.",
      "examples": [
        "claude --resume",
        "claude -r abc-123-uuid",
        "claude --resume abc-123-uuid \"continue the refactor\""
      ]
    },

    // ── --fork-session ────────────────────────────────────────────────────────
    "--fork-session": {
      "flags": ["--fork-session"],
      "type": "boolean",
      "default": false,
      "requires": "--resume or --continue",
      "description": "Start a new session ID when resuming, creating a fork rather than appending to the original.",
      "example": "claude --resume abc-123 --fork-session"
    },

    // ── --session-id ──────────────────────────────────────────────────────────
    "--session-id": {
      "flags": ["--session-id <uuid>"],
      "type": "string (UUID)",
      "description": "Pin the session to a fixed UUID. Useful for idempotent/scripted automation where you want a deterministic session handle.",
      "example": "claude --session-id 00000000-dead-beef-0000-000000000001 -p \"task\""
    },

    // ── -n / --name ───────────────────────────────────────────────────────────
    "--name": {
      "flags": ["-n <name>", "--name <name>"],
      "type": "string",
      "description": "Set a display name for the session (shown in /resume picker and terminal title).",
      "example": "claude --name \"stripe-migration\" -p \"start the refactor\""
    },

    // ── --no-session-persistence ──────────────────────────────────────────────
    "--no-session-persistence": {
      "flags": ["--no-session-persistence"],
      "type": "boolean",
      "default": false,
      "requires": "--print",
      "description": "Do not save this conversation to disk. The session cannot be resumed later.",
      "example": "claude -p --no-session-persistence \"one-off question\""
    }

  },

  // ---------------------------------------------------------------------------
  // MODEL & EFFORT
  // ---------------------------------------------------------------------------

  "model": {

    // ── --model ───────────────────────────────────────────────────────────────
    "--model": {
      "flags": ["--model <model>"],
      "type": "string",
      "description": "Override the AI model for this invocation. Accepts model alias (e.g. opus, sonnet) or full API ID (e.g. claude-opus-4-7).",
      "examples": [
        "claude --model claude-opus-4-7 \"hard problem\"",
        "claude --model sonnet -p \"quick summary\"",
        "claude --model claude-sonnet-4 --effort high"
      ]
    },

    // ── --effort ──────────────────────────────────────────────────────────────
    "--effort": {
      "flags": ["--effort <level>"],
      "type": "enum",
      "values": ["low", "medium", "high", "max"],
      "description": "Set the thinking/extended-reasoning budget for this invocation (case-insensitive).",
      "examples": [
        "claude --effort low -p \"what is 2+2\"",
        "claude --effort max \"refactor the auth module\"",
        "claude --model opus --effort high -p \"design the API\""
      ]
    },

    // ── --fallback-model ──────────────────────────────────────────────────────
    "--fallback-model": {
      "flags": ["--fallback-model <model>"],
      "type": "string",
      "requires": "--print",
      "description": "Model to fall back to when the primary model is overloaded.",
      "example": "claude -p --model opus --fallback-model sonnet \"run analysis\""
    },

    // ── --advisor ─────────────────────────────────────────────────────────────
    "--advisor": {
      "flags": ["--advisor <model>"],
      "type": "string",
      "description": "Enable an advisor model that critiques responses before they are sent. *feature* — only available when advisor is configurable for your account.",
      "example": "claude --advisor claude-opus-4-7 \"review this PR\""
    },

    // ── --thinking ────────────────────────────────────────────────────────────
    "--thinking": {
      "flags": ["--thinking <mode>"],
      "type": "enum",
      "values": ["enabled", "adaptive", "disabled"],
      "hidden": true,
      "description": "Fine-grained control over extended-thinking activation.",
      "example": "claude --thinking adaptive -p \"complex task\""
    },

    // ── --betas ───────────────────────────────────────────────────────────────
    "--betas": {
      "flags": ["--betas <betas...>"],
      "type": "string[]",
      "description": "Pass Anthropic API beta headers (for API-key users). Space-separated list.",
      "example": "claude --betas interleaved-thinking-2025-05-14 -p \"deep analysis\""
    }

  },

  // ---------------------------------------------------------------------------
  // PERMISSIONS & SAFETY
  // ---------------------------------------------------------------------------

  "permissions": {

    // ── --permission-mode ─────────────────────────────────────────────────────
    "--permission-mode": {
      "flags": ["--permission-mode <mode>"],
      "type": "enum",
      "values": ["default", "plan", "acceptEdits", "bypassPermissions", "dontAsk"],
      "description": "Control how Claude handles tool-use permission prompts.\n  default            — ask for permission on potentially destructive ops\n  plan               — read-only planning mode, no writes allowed\n  acceptEdits        — automatically accept file edits without prompting\n  bypassPermissions  — skip ALL permission checks (use with care)\n  dontAsk            — never prompt, auto-deny risky ops",
      "examples": [
        "claude --permission-mode plan \"what needs to change?\"",
        "claude --permission-mode acceptEdits \"apply the suggested fixes\"",
        "claude --permission-mode bypassPermissions -p \"run full automation script\""
      ]
    },

    // ── --dangerously-skip-permissions ────────────────────────────────────────
    "--dangerously-skip-permissions": {
      "flags": ["--dangerously-skip-permissions"],
      "type": "boolean",
      "default": false,
      "description": "Completely bypass all permission checks. WARNING: Claude will execute any tool call without confirmation. Use only in trusted automated environments.",
      "example": "claude --dangerously-skip-permissions -p \"deploy to staging\""
    },

    // ── --allowed-tools ───────────────────────────────────────────────────────
    "--allowed-tools": {
      "flags": ["--allowedTools <tools...>", "--allowed-tools <tools...>"],
      "type": "string[]",
      "description": "Explicit allowlist of tool names Claude may use. All other tools are blocked.",
      "examples": [
        "claude --allowed-tools Read Write -p \"edit the config file\"",
        "claude --allowed-tools Bash Read Write Glob Grep -p \"run the suite\""
      ]
    },

    // ── --tools ───────────────────────────────────────────────────────────────
    "--tools": {
      "flags": ["--tools <tools...>"],
      "type": "string[]",
      "description": "Set the built-in tool bundle. Pass 'default' for the standard set, an empty string to disable all built-ins, or specific tool names.",
      "examples": [
        "claude --tools default -p \"fix the bug\"",
        "claude --tools \"\" --mcp-config mcp.json -p \"mcp-only task\""
      ]
    },

    // ── --disallowed-tools ────────────────────────────────────────────────────
    "--disallowed-tools": {
      "flags": ["--disallowedTools <tools...>", "--disallowed-tools <tools...>"],
      "type": "string[]",
      "description": "Denylist of tool names Claude is NOT allowed to use.",
      "example": "claude --disallowed-tools Bash -p \"read-only audit of the repo\""
    },

    // ── --disable-slash-commands ──────────────────────────────────────────────
    "--disable-slash-commands": {
      "flags": ["--disable-slash-commands"],
      "type": "boolean",
      "default": false,
      "description": "Disable all slash commands (skills) from being loaded or invoked.",
      "example": "claude --disable-slash-commands -p \"raw task without skills\""
    }

  },

  // ---------------------------------------------------------------------------
  // SYSTEM PROMPT
  // ---------------------------------------------------------------------------

  "system-prompt": {

    // ── --system-prompt ───────────────────────────────────────────────────────
    "--system-prompt": {
      "flags": ["--system-prompt <prompt>"],
      "type": "string",
      "description": "Fully replace the default system prompt with a custom one.",
      "example": "claude --system-prompt \"You are a senior Go engineer. Only respond in Go code snippets.\" -p \"implement a ring buffer\""
    },

    // ── --system-prompt-file ──────────────────────────────────────────────────
    "--system-prompt-file": {
      "flags": ["--system-prompt-file <file>"],
      "type": "string (file path)",
      "hidden": true,
      "description": "Read the replacement system prompt from a file.",
      "example": "claude --system-prompt-file ./prompts/my-persona.txt -p \"task\""
    },

    // ── --append-system-prompt ────────────────────────────────────────────────
    "--append-system-prompt": {
      "flags": ["--append-system-prompt <prompt>"],
      "type": "string",
      "description": "Append extra instructions to the default system prompt (keeps all default behaviour, just adds more).",
      "example": "claude --append-system-prompt \"Always add JSDoc comments to every function you write.\" \"refactor the utils module\""
    },

    // ── --append-system-prompt-file ───────────────────────────────────────────
    "--append-system-prompt-file": {
      "flags": ["--append-system-prompt-file <file>"],
      "type": "string (file path)",
      "hidden": true,
      "description": "Append system prompt from a file instead of inline.",
      "example": "claude --append-system-prompt-file ./rules.txt -p \"fix lint errors\""
    }

  },

  // ---------------------------------------------------------------------------
  // MCP CONFIG
  // ---------------------------------------------------------------------------

  "mcp": {

    // ── --mcp-config ──────────────────────────────────────────────────────────
    "--mcp-config": {
      "flags": ["--mcp-config <configs...>"],
      "type": "string[] (file paths or JSON strings)",
      "description": "Load MCP server configuration from JSON files or inline JSON strings. Repeatable.",
      "examples": [
        "claude --mcp-config ./mcp.json -p \"query the database\"",
        "claude --mcp-config mcp-github.json mcp-postgres.json -p \"compare PRs\""
      ]
    },

    // ── --strict-mcp-config ───────────────────────────────────────────────────
    "--strict-mcp-config": {
      "flags": ["--strict-mcp-config"],
      "type": "boolean",
      "default": false,
      "description": "Only use MCP servers from --mcp-config. Ignore all project-level and user-level MCP configuration.",
      "example": "claude --strict-mcp-config --mcp-config ./mcp.json -p \"isolated task\""
    },

    // ── --permission-prompt-tool ──────────────────────────────────────────────
    "--permission-prompt-tool": {
      "flags": ["--permission-prompt-tool <tool>"],
      "type": "string (MCP tool name)",
      "hidden": true,
      "requires": "--print",
      "description": "Delegate permission prompts to an MCP tool instead of stdin/stdout.",
      "example": "claude -p --permission-prompt-tool my_server__grant_permission \"run automation\""
    }

  },

  // ---------------------------------------------------------------------------
  // WORKSPACE & DIRECTORIES
  // ---------------------------------------------------------------------------

  "workspace": {

    // ── --add-dir ─────────────────────────────────────────────────────────────
    "--add-dir": {
      "flags": ["--add-dir <directories...>"],
      "type": "string[]",
      "description": "Grant Claude access to additional directories outside the cwd. Repeatable.",
      "examples": [
        "claude --add-dir ../shared-libs -p \"use the shared auth module\"",
        "claude --add-dir /etc/nginx /var/log/nginx -p \"diagnose nginx config\""
      ]
    },

    // ── --settings ────────────────────────────────────────────────────────────
    "--settings": {
      "flags": ["--settings <file-or-json>"],
      "type": "string (file path or inline JSON)",
      "description": "Load extra settings from a JSON file or an inline JSON string. Merged on top of user/project settings.",
      "examples": [
        "claude --settings ./ci-settings.json -p \"run ci task\"",
        "claude --settings '{\"permissions\":{\"allow\":[\"Bash\"]}}' -p \"run bash\""
      ]
    },

    // ── --setting-sources ─────────────────────────────────────────────────────
    "--setting-sources": {
      "flags": ["--setting-sources <sources>"],
      "type": "string (comma-separated: user,project,local)",
      "description": "Restrict which settings layers are loaded. Useful to ignore project-level rules in automation.",
      "examples": [
        "claude --setting-sources user -p \"ignore project overrides\"",
        "claude --setting-sources user,project -p \"no local overrides\""
      ]
    },

    // ── --plugin-dir ──────────────────────────────────────────────────────────
    "--plugin-dir": {
      "flags": ["--plugin-dir <path>"],
      "type": "string[] (repeatable)",
      "default": "[]",
      "description": "Load plugins from additional directories. Can be passed multiple times.",
      "example": "claude --plugin-dir ~/my-plugins --plugin-dir ./team-plugins"
    }

  },

  // ---------------------------------------------------------------------------
  // BUDGET & LIMITS
  // ---------------------------------------------------------------------------

  "budget": {

    // ── --max-turns ───────────────────────────────────────────────────────────
    "--max-turns": {
      "flags": ["--max-turns <turns>"],
      "type": "number",
      "hidden": true,
      "requires": "--print",
      "description": "Cap the number of agentic turns (tool-use cycles) before Claude stops.",
      "example": "claude -p --max-turns 5 \"run the build and fix errors\""
    },

    // ── --max-budget-usd ──────────────────────────────────────────────────────
    "--max-budget-usd": {
      "flags": ["--max-budget-usd <amount>"],
      "type": "number (positive float)",
      "description": "Hard USD spending cap for this invocation. Claude stops when the limit is reached.",
      "example": "claude --max-budget-usd 0.50 -p \"large analysis task\""
    },

    // ── --task-budget ─────────────────────────────────────────────────────────
    "--task-budget": {
      "flags": ["--task-budget <tokens>"],
      "type": "number (positive int)",
      "hidden": true,
      "description": "API-level token budget for the task.",
      "example": "claude -p --task-budget 50000 \"long task\""
    }

  },

  // ---------------------------------------------------------------------------
  // DEBUG & VERBOSITY
  // ---------------------------------------------------------------------------

  "debug": {

    // ── --debug ───────────────────────────────────────────────────────────────
    "--debug": {
      "flags": ["-d [filter]", "--debug [filter]"],
      "type": "boolean or optional string",
      "default": false,
      "description": "Enable debug logging. Optional filter string limits output to matching categories.",
      "examples": [
        "claude --debug",
        "claude -d mcp \"list servers\"",
        "claude --debug tools -p \"run task\""
      ]
    },

    // ── --verbose ─────────────────────────────────────────────────────────────
    "--verbose": {
      "flags": ["--verbose"],
      "type": "boolean",
      "default": false,
      "description": "Override the verbose setting from config — show more output than default.",
      "example": "claude --verbose -p \"build the app\""
    },

    // ── --debug-to-stderr ─────────────────────────────────────────────────────
    "--debug-to-stderr": {
      "flags": ["--debug-to-stderr"],
      "type": "boolean",
      "hidden": true,
      "description": "Route debug output to stderr instead of stdout (useful when stdout is consumed by a pipe).",
      "example": "claude --debug-to-stderr -p \"task\" 2>debug.log"
    },

    // ── --debug-file ──────────────────────────────────────────────────────────
    "--debug-file": {
      "flags": ["--debug-file <path>"],
      "type": "string (file path)",
      "description": "Write all debug logs to a file and enable debug mode automatically.",
      "example": "claude --debug-file /tmp/claude-debug.log -p \"hard task\""
    }

  },

  // ---------------------------------------------------------------------------
  // IDE & INTEGRATIONS
  // ---------------------------------------------------------------------------

  "integrations": {

    // ── --ide ─────────────────────────────────────────────────────────────────
    "--ide": {
      "flags": ["--ide"],
      "type": "boolean",
      "default": false,
      "description": "Auto-connect to an IDE (Cursor / VS Code) when exactly one compatible IDE is detected.",
      "example": "claude --ide"
    },

    // ── --chrome ──────────────────────────────────────────────────────────────
    "--chrome": {
      "flags": ["--chrome"],
      "type": "boolean",
      "description": "Enable Claude-in-Chrome integration for this session.",
      "example": "claude --chrome"
    },

    // ── --file ────────────────────────────────────────────────────────────────
    "--file": {
      "flags": ["--file <specs...>"],
      "type": "string[] (format: file_id:path)",
      "description": "Download remote file attachments into local paths before starting. Requires CLAUDE_CODE_SESSION_ACCESS_TOKEN env var.",
      "example": "claude --file abc123:/tmp/attachment.pdf -p \"summarise the PDF\""
    }

  },

  // ---------------------------------------------------------------------------
  // WORKTREE (git worktree integration)
  // ---------------------------------------------------------------------------

  "worktree": {

    // ── -w / --worktree ───────────────────────────────────────────────────────
    "--worktree": {
      "flags": ["-w [name]", "--worktree [name]"],
      "type": "string | boolean",
      "description": "Create or reuse a git worktree for this session. Keeps work isolated from main branch.",
      "examples": [
        "claude -w",
        "claude --worktree feature-x",
        "claude -w my-experiment --tmux"
      ]
    },

    // ── --tmux ────────────────────────────────────────────────────────────────
    "--tmux": {
      "flags": ["--tmux", "--tmux=classic"],
      "type": "boolean | 'classic'",
      "requires": "--worktree",
      "description": "Run the session inside a tmux pane attached to the worktree. 'classic' uses the classic tmux layout.",
      "examples": [
        "claude -w my-branch --tmux",
        "claude -w experiment --tmux=classic"
      ]
    }

  },

  // ---------------------------------------------------------------------------
  // BARE / SIMPLE MODE
  // ---------------------------------------------------------------------------

  "--bare": {
    "flags": ["--bare"],
    "type": "boolean",
    "default": false,
    "description": "Minimal mode — disables plugins, decorations, and extra features. Sets CLAUDE_CODE_SIMPLE=1. Useful for embedding Claude in other tools.",
    "example": "claude --bare -p \"task\""
  },

  // ---------------------------------------------------------------------------
  // SUBCOMMANDS
  // ---------------------------------------------------------------------------

  "subcommands": {

    // =========================================================================
    // claude mcp
    // =========================================================================
    "mcp": {
      "description": "Manage MCP (Model Context Protocol) servers in Claude's config.",
      "usage": "claude mcp <subcommand> [options]",

      "subcommands": {

        // ── claude mcp add ────────────────────────────────────────────────────
        "add": {
          "usage": "claude mcp add <name> <command-or-url> [args...]",
          "description": "Register a new MCP server.",
          "params": {
            "<name>": "Required. Unique identifier for this server.",
            "<command-or-url>": "Required. Shell command to spawn (stdio) or HTTP/SSE URL."
          },
          "flags": {
            "-s, --scope <scope>": "Where to save: 'local' (project .claude/), 'user' (~/.claude/), or 'project' (shared). Default: 'local'.",
            "-t, --transport <transport>": "Transport type: 'stdio', 'sse', or 'http'. Default: auto-detected.",
            "-e, --env <KEY=VALUE>": "Inject env vars into the server process. Repeatable.",
            "-H, --header <name:value>": "HTTP headers for SSE/HTTP transport. Repeatable.",
            "--client-id <id>": "OAuth client ID for authenticated servers.",
            "--client-secret <secret>": "OAuth client secret (or set MCP_CLIENT_SECRET env var).",
            "--callback-port <port>": "Local port for OAuth callback listener."
          },
          "examples": [
            "claude mcp add github npx @modelcontextprotocol/server-github",
            "claude mcp add postgres npx @modelcontextprotocol/server-postgres -e DATABASE_URL=postgresql://localhost/mydb",
            "claude mcp add my-api https://api.example.com/mcp --transport sse -H Authorization:Bearer $TOKEN",
            "claude mcp add github npx @modelcontextprotocol/server-github --scope user"
          ]
        },

        // ── claude mcp add-json ───────────────────────────────────────────────
        "add-json": {
          "usage": "claude mcp add-json <name> <json>",
          "description": "Register a server from a raw JSON config string.",
          "flags": {
            "-s, --scope <scope>": "Where to save. Default: 'local'.",
            "--client-secret <secret>": "OAuth secret (or MCP_CLIENT_SECRET env)."
          },
          "example": "claude mcp add-json my-server '{\"command\":\"npx\",\"args\":[\"my-mcp-server\"]}'"
        },

        // ── claude mcp add-from-claude-desktop ────────────────────────────────
        "add-from-claude-desktop": {
          "usage": "claude mcp add-from-claude-desktop",
          "description": "Import all MCP servers from the Claude desktop app config (~/.config/Claude/claude_desktop_config.json).",
          "flags": {
            "-s, --scope <scope>": "Where to save. Default: 'local'."
          },
          "example": "claude mcp add-from-claude-desktop --scope user"
        },

        // ── claude mcp remove ─────────────────────────────────────────────────
        "remove": {
          "usage": "claude mcp remove <name>",
          "description": "Unregister an MCP server.",
          "flags": {
            "-s, --scope <scope>": "Scope to remove from (optional)."
          },
          "example": "claude mcp remove github"
        },

        // ── claude mcp list ───────────────────────────────────────────────────
        "list": {
          "usage": "claude mcp list",
          "description": "Show all registered MCP servers and their status.",
          "example": "claude mcp list"
        },

        // ── claude mcp get ────────────────────────────────────────────────────
        "get": {
          "usage": "claude mcp get <name>",
          "description": "Show the config details for a specific MCP server.",
          "example": "claude mcp get github"
        },

        // ── claude mcp serve ──────────────────────────────────────────────────
        "serve": {
          "usage": "claude mcp serve",
          "description": "Start Claude as an MCP server (exposes Claude as an MCP tool to other apps).",
          "flags": {
            "-d, --debug": "Enable debug logging.",
            "--verbose": "Verbose output."
          },
          "example": "claude mcp serve --debug"
        },

        // ── claude mcp reset-project-choices ─────────────────────────────────
        "reset-project-choices": {
          "usage": "claude mcp reset-project-choices",
          "description": "Clear cached approval/denial decisions for MCP server prompts.",
          "example": "claude mcp reset-project-choices"
        }

      }
    },

    // =========================================================================
    // claude auth
    // =========================================================================
    "auth": {
      "description": "Manage authentication credentials.",
      "usage": "claude auth <subcommand>",

      "subcommands": {

        "login": {
          "usage": "claude auth login",
          "description": "Authenticate with Anthropic. Opens a browser OAuth flow by default.",
          "flags": {
            "--email <email>": "Pre-fill email address.",
            "--sso": "Use SSO login flow.",
            "--console": "Print auth URL to terminal instead of opening browser.",
            "--claudeai": "Log in via claude.ai account instead of API key."
          },
          "examples": [
            "claude auth login",
            "claude auth login --console",
            "claude auth login --claudeai"
          ]
        },

        "logout": {
          "usage": "claude auth logout",
          "description": "Remove stored credentials.",
          "example": "claude auth logout"
        },

        "status": {
          "usage": "claude auth status",
          "description": "Show current auth state and account details.",
          "flags": {
            "--json": "Output as JSON.",
            "--text": "Output as plain text."
          },
          "examples": [
            "claude auth status",
            "claude auth status --json"
          ]
        }

      }
    },

    // =========================================================================
    // claude doctor
    // =========================================================================
    "doctor": {
      "usage": "claude doctor",
      "description": "Run a health-check: tests environment, permissions, MCP connectivity, and reports any issues.",
      "example": "claude doctor"
    },

    // =========================================================================
    // claude update / upgrade
    // =========================================================================
    "update": {
      "usage": "claude update",
      "aliases": ["upgrade"],
      "description": "Check for and install the latest version of Claude Code.",
      "examples": [
        "claude update",
        "claude upgrade"
      ]
    },

    // =========================================================================
    // claude plugin / plugins
    // =========================================================================
    "plugin": {
      "description": "Manage Claude Code plugins.",
      "usage": "claude plugin <subcommand> [options]",
      "aliases": ["plugins"],

      "subcommands": {

        "list": {
          "usage": "claude plugin list",
          "description": "List all installed plugins.",
          "example": "claude plugin list"
        },

        "install": {
          "usage": "claude plugin install <plugin-name-or-path>",
          "aliases": ["i"],
          "description": "Install a plugin from the marketplace or a local path.",
          "flags": {
            "--sparse": "Sparse install (skip optional deps)."
          },
          "examples": [
            "claude plugin install @anthropic/security-review",
            "claude plugin install ./my-local-plugin"
          ]
        },

        "uninstall": {
          "usage": "claude plugin uninstall <plugin-name>",
          "aliases": ["remove", "rm"],
          "description": "Uninstall a plugin.",
          "flags": {
            "--keep-data": "Preserve plugin data directory after uninstall."
          },
          "example": "claude plugin uninstall @anthropic/security-review"
        },

        "enable": {
          "usage": "claude plugin enable <plugin-name>",
          "description": "Enable a previously disabled plugin.",
          "example": "claude plugin enable @anthropic/security-review"
        },

        "disable": {
          "usage": "claude plugin disable <plugin-name>",
          "description": "Disable a plugin without uninstalling it.",
          "example": "claude plugin disable @anthropic/security-review"
        },

        "update": {
          "usage": "claude plugin update [plugin-name]",
          "description": "Update a specific plugin or all plugins when no name is given.",
          "flags": {
            "-a, --all": "Update all installed plugins."
          },
          "examples": [
            "claude plugin update",
            "claude plugin update @anthropic/security-review",
            "claude plugin update --all"
          ]
        },

        "validate": {
          "usage": "claude plugin validate <path>",
          "description": "Validate a local plugin directory against the plugin schema.",
          "example": "claude plugin validate ./my-plugin"
        },

        "marketplace": {
          "usage": "claude plugin marketplace <add|list|remove>",
          "description": "Manage marketplace registry sources.",
          "examples": [
            "claude plugin marketplace list",
            "claude plugin marketplace add https://my.registry.com",
            "claude plugin marketplace remove https://my.registry.com"
          ]
        }

      }
    },

    // =========================================================================
    // claude server  (*feature* DIRECT_CONNECT)
    // =========================================================================
    "server": {
      "usage": "claude server [options]",
      "description": "Start Claude Code as a standalone HTTP/Unix server that other processes can connect to.",
      "flags": {
        "--port <port>": "TCP port to listen on. Default: '0' (OS-assigned).",
        "--host <host>": "Bind address. Default: '0.0.0.0'.",
        "--auth-token <token>": "Bearer token clients must present.",
        "--unix <socket-path>": "Listen on a Unix domain socket instead of TCP.",
        "--workspace <path>": "Working directory for the server session.",
        "--idle-timeout <ms>": "Shut down after N ms of inactivity. Default: 600000 (10 min).",
        "--max-sessions <n>": "Maximum concurrent sessions. Default: 32."
      },
      "examples": [
        "claude server --port 3000 --auth-token secret",
        "claude server --unix /tmp/claude.sock --workspace /repo",
        "claude server --port 0 --max-sessions 8 --idle-timeout 300000"
      ]
    },

    // =========================================================================
    // claude ssh  (*feature* SSH_REMOTE)
    // =========================================================================
    "ssh": {
      "usage": "claude ssh <host> [dir]",
      "description": "Open a Claude session on a remote host via SSH.",
      "params": {
        "<host>": "SSH host (user@hostname or ssh-config alias).",
        "[dir]": "Working directory on the remote host."
      },
      "flags": {
        "--permission-mode <mode>": "Same values as global --permission-mode.",
        "--dangerously-skip-permissions": "Skip permission checks remotely.",
        "--local": "Run locally even if a remote is configured.",
        "-c, --continue": "Continue latest remote conversation.",
        "--resume [id]": "Resume by session ID on the remote.",
        "--model <model>": "Model for the remote session."
      },
      "examples": [
        "claude ssh user@prod-server /var/www/app",
        "claude ssh deploy-box --permission-mode acceptEdits"
      ]
    }

  },

  // ---------------------------------------------------------------------------
  // ENVIRONMENT VARIABLES
  // ---------------------------------------------------------------------------

  "env": {

    "ANTHROPIC_API_KEY": {
      "description": "Anthropic API key. Required for API-key auth mode.",
      "example": "ANTHROPIC_API_KEY=sk-ant-... claude -p \"task\""
    },

    "ANTHROPIC_BASE_URL": {
      "description": "Override the Anthropic API base URL (proxy, self-hosted, etc.).",
      "example": "ANTHROPIC_BASE_URL=https://my-proxy.com claude -p \"task\""
    },

    "CLAUDE_CONFIG_DIR": {
      "description": "Override the config home directory. Default: ~/.claude",
      "example": "CLAUDE_CONFIG_DIR=/tmp/ci-claude claude -p \"task\""
    },

    "CLAUDE_CODE_SIMPLE": {
      "description": "Set to '1' to activate bare/simple mode (same as --bare).",
      "example": "CLAUDE_CODE_SIMPLE=1 claude -p \"task\""
    },

    "CLAUDE_CODE_REMOTE": {
      "description": "Set to 'true' inside cloud/remote run environments. Increases Node heap and adjusts hook handling.",
      "example": "CLAUDE_CODE_REMOTE=true claude -p \"cloud task\""
    },

    "CLAUDE_CODE_AGENT": {
      "description": "Default agent to use (equivalent to --agent). Only active when BG_SESSIONS feature is enabled.",
      "example": "CLAUDE_CODE_AGENT=my-agent claude -p \"task\""
    },

    "CLAUDE_CODE_SESSION_ACCESS_TOKEN": {
      "description": "Required for --file downloads from remote sessions.",
      "example": "CLAUDE_CODE_SESSION_ACCESS_TOKEN=token claude --file id123:./local.pdf -p \"read the PDF\""
    },

    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": {
      "description": "Set to any truthy value to prevent Claude from setting the terminal process title.",
      "example": "CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1 claude"
    },

    "DISABLE_COMPACT": {
      "description": "Set to '1' to disable the /compact slash command entirely.",
      "example": "DISABLE_COMPACT=1 claude"
    },

    "MCP_CLIENT_SECRET": {
      "description": "OAuth client secret for 'claude mcp add' and 'claude mcp add-json' (alternative to --client-secret flag).",
      "example": "MCP_CLIENT_SECRET=mysecret claude mcp add my-server https://example.com/mcp"
    },

    "CLAUDE_CODE_ENABLE_XAA": {
      "description": "Set to '1' to enable the --xaa flag on 'claude mcp add' (XAA IDP auth).",
      "example": "CLAUDE_CODE_ENABLE_XAA=1 claude mcp add server cmd --xaa"
    },

    "X402_PRIVATE_KEY": {
      "description": "Override the x402 payment wallet private key (for CI/automation without interactive setup).",
      "example": "X402_PRIVATE_KEY=0xabc123 claude -p \"pay-gated API task\""
    }

  },

  // ---------------------------------------------------------------------------
  // COMMON USAGE PATTERNS
  // ---------------------------------------------------------------------------

  "recipes": {

    "pipe-stdin-to-claude": {
      "description": "Pipe text into Claude and get a response on stdout.",
      "example": "cat error.log | claude -p \"what caused this error?\""
    },

    "json-output-for-scripts": {
      "description": "Get a clean JSON response suitable for jq parsing.",
      "example": "claude -p --output-format json \"list the top 5 files by line count\" | jq '.result'"
    },

    "stream-json-pipeline": {
      "description": "Stream events for real-time monitoring of a long task.",
      "example": "claude -p --output-format stream-json --include-partial-messages \"run the full test suite and fix failures\" | jq -r 'select(.type==\"assistant\") | .content'"
    },

    "one-off-task-no-history": {
      "description": "Run a task without persisting it to session history.",
      "example": "claude -p --no-session-persistence \"generate a UUID\""
    },

    "ci-safe-run": {
      "description": "CI-friendly invocation: no prompts, explicit permissions, JSON output.",
      "example": "claude -p --dangerously-skip-permissions --output-format json --no-session-persistence --max-turns 10 \"run tests and report results\""
    },

    "use-custom-mcp": {
      "description": "One-off run with a project-specific MCP server.",
      "example": "claude --mcp-config ./mcp.json --strict-mcp-config -p \"query the database for user count\""
    },

    "continue-latest-conversation": {
      "description": "Pick up exactly where you left off in the current directory.",
      "example": "claude -c \"now add error handling to that function\""
    },

    "resume-by-id": {
      "description": "Resume a specific past session by ID.",
      "example": "claude --resume abc-123-uuid \"continue the refactor\""
    },

    "use-specific-model-and-effort": {
      "description": "Override model and effort for a demanding task.",
      "example": "claude --model claude-opus-4-7 --effort max \"design the full database schema\""
    },

    "plan-mode-read-only": {
      "description": "Let Claude analyse and plan without making any changes.",
      "example": "claude --permission-mode plan \"what changes would migrate this to TypeScript?\""
    },

    "append-custom-rules": {
      "description": "Add project-specific coding rules on top of the defaults.",
      "example": "claude --append-system-prompt \"Always use the Result<T,E> pattern for error handling.\" \"implement the new endpoint\""
    },

    "worktree-with-tmux": {
      "description": "Isolate work in a git worktree and attach a tmux pane.",
      "example": "claude -w try-new-approach --tmux"
    }

  }

}
