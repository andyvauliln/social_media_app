      "example": "/statusline"
    },

    // ── /stickers ─────────────────────────────────────────────────────────────
    "stickers": {
      "aliases": [],
      "description": "Manage decorative stickers shown in the UI.",
      "params": "none",
      "example": "/stickers"
    },

    // ── /keybindings ──────────────────────────────────────────────────────────
    "keybindings": {
      "aliases": [],
      "description": "View and customise keyboard shortcuts.",
      "params": "none",
      "example": "/keybindings"
    },

    // ── /vim ──────────────────────────────────────────────────────────────────
    "vim": {
