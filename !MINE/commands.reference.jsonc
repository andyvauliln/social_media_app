      "description": "Set the prompt bar accent color for this session.",
      "params": "<color | default>  — CSS color name, hex value, or 'default' to reset",
      "examples": [
        "/color default",
        "/color #6366f1",
        "/color teal"
      ]
    },

    // ── /output-style ─────────────────────────────────────────────────────────
    "output-style": {
      "aliases": [],
      "description": "Change how Claude formats its responses (concise / verbose / streaming, etc.).",
